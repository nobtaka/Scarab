{
    "manifest_version": 3,
    "default_locale": "en",

    "name": "__MSG_extension_name__",
    "description": "__MSG_extension_description__",
    "version": "1.0",

    "icons": {
        "48": "images/icon-48.png",
        "96": "images/icon-96.png",
        "128": "images/icon-128.png",
        "256": "images/icon-256.png",
        "512": "images/icon-512.png"
    },

    "background": {
        "scripts": [ "background.js" ],
        "type": "module"
    },

    "content_scripts": [{
        "js": [ "content.js" ],
        "matches": [
            "*://*.amazon.co.jp/*",
            "*://*.amazon.com/*",
            "*://*.amazon.co.uk/*",
            "*://*.amazon.de/*",
            "*://*.amazon.fr/*",
            "*://*.amazon.it/*",
            "*://*.amazon.es/*",
            "*://*.amazon.ca/*",
            "*://*.amazon.com.au/*",
            "*://*.amazon.com.br/*",
            "*://*.amazon.in/*",
            "*://*.amazon.sg/*",
            "*://*.amazon.com.mx/*",
            "*://*.amazon.nl/*",
            "*://*.amazon.se/*",
            "*://*.amazon.pl/*",
            "*://*.amazon.com.be/*",
            "*://*.amazon.sa/*",
            "*://*.amazon.ae/*",
            "*://*.amazon.eg/*"
        ],
        "run_at": "document_start"
    }],

    "action": {
        "default_popup": "popup.html",
        "default_icon": "images/toolbar-icon.svg"
    },

    "permissions": [],

    "host_permissions": [
        "*://*.amazon.co.jp/*",
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.de/*",
        "*://*.amazon.fr/*",
        "*://*.amazon.it/*",
        "*://*.amazon.es/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.com.au/*",
        "*://*.amazon.com.br/*",
        "*://*.amazon.in/*",
        "*://*.amazon.sg/*",
        "*://*.amazon.com.mx/*",
        "*://*.amazon.nl/*",
        "*://*.amazon.se/*",
        "*://*.amazon.pl/*",
        "*://*.amazon.com.be/*",
        "*://*.amazon.sa/*",
        "*://*.amazon.ae/*",
        "*://*.amazon.eg/*"
    ]
}
